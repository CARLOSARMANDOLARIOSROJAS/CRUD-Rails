<div id="<%= dom_id tarea %>" class="card shadow-sm border-0 rounded p-4">
  <h2 class="text-primary mb-3 text-center">Task Details</h2>

  <div class="mb-2">
    <strong class="text-secondary">Titulo:</strong>
    <p class="fw-bold text-dark"><%= tarea.titulo %></p>
  </div>

  <div class="mb-3">
    <strong class="text-secondary">Descripcion:</strong>
    <p class="text-muted"><%= tarea.descripcion %></p>
  </div>

</div>
