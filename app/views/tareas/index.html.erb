<p class="text-success"><%= notice %></p>

<% content_for :title, "Tareas" %>

<h1 class="text-center my-4">Tasks CRUD</h1>

<div id="tareas" class="container">
  <div class="row">
    <% @tareas.each do |tarea| %>
      <div class="col-md-4 mb-3">
        <div class="card">
          <div class="card-body">
            <h5 class="card-title"><%= tarea.titulo %></h5>
            <p class="card-text"><%= tarea.descripcion %></p>
            <%= link_to "Details", tarea, class: "btn btn-info" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>

<div class="container text-center my-4">
  <%= link_to "Add new task", new_tarea_path, class: "btn btn-success" %>
</div>
