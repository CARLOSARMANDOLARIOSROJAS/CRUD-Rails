<p class="text-success"><%= notice %></p>

<div class="container">
  <%= render @tarea %>

  <div class="d-flex justify-content-center gap-3 mt-4">
    <%= link_to "Edit Task", edit_tarea_path(@tarea), class: "btn btn-warning" %>
    <%= link_to "Back to Tasks", tareas_path, class: "btn btn-secondary" %>
    <%= button_to "Delete Task", @tarea, method: :delete, class: "btn btn-danger", data: { confirm: "Are you sure you want to delete this task?" } %>
  </div>
</div>
