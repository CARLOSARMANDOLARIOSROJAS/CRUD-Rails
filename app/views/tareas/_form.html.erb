<div class="d-flex justify-content-center align-items-center mt-5 "> 
  <%= form_with(model: tarea) do |form| %>
    <% if tarea.errors.any? %>
      <div style="color: red">
        <h2><%= pluralize(tarea.errors.count, "error") %> prohibited this tarea from being saved:</h2>

        <ul>
          <% tarea.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>
    <h1 class="text-primary">Create New Task</h1>

    <div class="d-flex flex-column">
      <h3>Titulo</h3>
      <%= form.text_field :titulo %>
    </div>

    <div class="d-flex flex-column mt-2">
      <h3>Description</h3>
      <%= form.textarea :descripcion %>
    </div>

    <div class="d-flex flex-column justify-content-center align-items-center">
      <div class="mt-3">
        <%= form.submit tarea.new_record? ? "Create Task" : "Update Task", class: "btn btn-primary" %>
      </div>

      <div class="mt-3">
        <%= link_to "Back to tasks", tareas_path, class: "btn btn-warning text-decoration-none" %>
      </div>
    </div>

  <% end %>
</div>
